:root {
  /* Design Tokens */
  --primary-color: #2563eb;
  --bg-main: #ffffff;
  --spacing-unit: 8px;
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

[data-theme="dark"] {
  --primary-color: #60a5fa;
  --bg-main: #1f2937;
}

.card {
  background-color: var(--bg-main);
  padding: calc(var(--spacing-unit) * 2);
  box-shadow: var(--shadow-lg);
}
